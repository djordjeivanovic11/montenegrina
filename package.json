{
  "name": "montenegrina",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test -- --exclude '**/dist/**'",
    "test:unit": "turbo run test:unit -- --exclude '**/dist/**'",
    "test:integration": "turbo run test:integration -- --exclude '**/dist/**'",
    "contracts:check": "pnpm --filter @montenegrina/contracts check",
    "openapi:generate": "pnpm --filter @montenegrina/contracts build",
    "sdk:generate": "pnpm --filter @montenegrina/sdk-typescript generate",
    "db:generate": "pnpm --filter @montenegrina/database generate",
    "db:migrate": "pnpm --filter @montenegrina/database migrate",
    "db:seed": "pnpm --filter @montenegrina/database seed",
    "evals": "pnpm --filter @montenegrina/evals run fixtures",
    "compose:config": "docker compose config --quiet",
    "local": "./run_local",
    "deploy": "./deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.7.0",
    "turbo": "^2.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.0"
  }
}
