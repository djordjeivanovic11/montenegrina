#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

LOCAL_ENV_FILE="${LOCAL_ENV_FILE:-.env.development}"
LOCAL_ENV_EXAMPLE="${LOCAL_ENV_EXAMPLE:-.env.development.example}"

compose() {
  if [[ -f "$LOCAL_ENV_FILE" ]]; then
    docker compose --env-file "$LOCAL_ENV_FILE" "$@"
  else
    docker compose "$@"
  fi
}

case "${1:-up}" in
  down)
    compose down --remove-orphans
    exit $?
    ;;
  logs)
    compose logs --follow --tail=200 "${@:2}"
    exit $?
    ;;
  status)
    compose ps
    exit $?
    ;;
  up)
    ;;
  *)
    echo "Usage: ./run_local [up|down|logs|status]" >&2
    exit 2
    ;;
esac

command -v docker >/dev/null || { echo "Docker is required." >&2; exit 1; }
docker compose version >/dev/null

if [[ ! -f "$LOCAL_ENV_FILE" ]]; then
  cp "$LOCAL_ENV_EXAMPLE" "$LOCAL_ENV_FILE"
  echo "Created $LOCAL_ENV_FILE from $LOCAL_ENV_EXAMPLE." >&2
  if [[ -f .env ]]; then
    echo "Local env created. Copy real provider keys from .env into $LOCAL_ENV_FILE if needed." >&2
  fi
fi

env_value() {
  local key="$1"
  sed -n "s/^${key}=//p" "$LOCAL_ENV_FILE" | tail -n 1
}

stt_provider="$(env_value VOICE_STT_PROVIDER)"
tts_provider="$(env_value VOICE_TTS_PROVIDER)"
if [[ -z "${RATE_LIMIT_VOICE_SESSIONS_PER_HOUR:-}" ]]; then
  configured_voice_limit="$(env_value RATE_LIMIT_VOICE_SESSIONS_PER_HOUR)"
  if [[ "$configured_voice_limit" =~ ^[0-9]+$ && "$configured_voice_limit" -gt 60 ]]; then
    export RATE_LIMIT_VOICE_SESSIONS_PER_HOUR="$configured_voice_limit"
  else
    export RATE_LIMIT_VOICE_SESSIONS_PER_HOUR=60
  fi
fi
required=(OPENAI_API_KEY)
if [[ "${stt_provider:-openai}" == "deepgram" ]]; then
  required+=(DEEPGRAM_API_KEY)
fi
if [[ "${tts_provider:-elevenlabs}" == "elevenlabs" ]]; then
  required+=(ELEVENLABS_API_KEY ELEVENLABS_MONTENEGRIN_VOICE_ID)
fi
missing=()
for key in "${required[@]}"; do
  if ! grep -Eq "^${key}=.+" "$LOCAL_ENV_FILE"; then missing+=("$key"); fi
done
if ((${#missing[@]})); then
  echo "Set these real-provider values in $LOCAL_ENV_FILE before startup: ${missing[*]}" >&2
  exit 1
fi

compose up --build --remove-orphans --wait

echo "Montenegrina is ready:"
echo "  Web:       http://localhost:3000"
echo "  API:       http://localhost:3001"
echo "  OpenAPI:   http://localhost:3001/openapi.yaml"
echo "  MinIO:     http://localhost:9001"
echo "  Grafana:   http://localhost:3002"
echo "  Jaeger:    http://localhost:16686"
echo "Use './run_local logs' to follow logs and './run_local down' to stop."
