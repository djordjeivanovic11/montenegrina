# Private production-style application env template.
# Local Docker development uses .env.development, created by ./run_local.
# Azure deployment inputs use .env.azure, created by scripts/azure-prepare-env.sh.

NODE_ENV=production
API_PORT=3001
WEB_PORT=3000
PUBLIC_WEB_URL=https://voice.mne-mcp.com
PUBLIC_API_URL=https://api.voice.mne-mcp.com
PUBLIC_LIVEKIT_URL=wss://<livekit-project>.livekit.cloud
PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

INTERNAL_API_URL=http://api:3001
DATABASE_URL=
REDIS_URL=

STORAGE_BACKEND=azure
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=montenegrina
AZURE_CLIENT_ID=

SESSION_SECRET=
INTERNAL_TOKEN_SECRET=
VOICE_AGENT_SERVICE_SECRET=
COOKIE_SECURE=true
CORS_ORIGINS=https://voice.mne-mcp.com

LIVEKIT_URL=wss://<livekit-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_SIP_INBOUND_TRUNK_ID=
LIVEKIT_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536

VOICE_STT_PROVIDER=openai
VOICE_TTS_PROVIDER=elevenlabs
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_MONTENEGRIN_VOICE_ID=

REGISTRATION_ENABLED=true
BILLING_ENABLED=false
WEBHOOKS_ENABLED=false
PHONE_INTEGRATIONS_ENABLED=false
RECORDINGS_ENABLED=false
PUBLIC_DEMO_ENABLED=false
SENTRY_DSN=
SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=info

TRANSCRIPT_RETENTION_DAYS=30
AUDIO_RETENTION_DAYS=7
AUDIT_RETENTION_DAYS=365
EVALUATION_RETENTION_DAYS=90
MAX_CONVERSATION_MINUTES=30
MAX_CONCURRENT_SESSIONS=25
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_VOICE_SESSIONS_PER_HOUR=3

KNOWLEDGE_PARSER_URL=http://knowledge-parser:8090
KNOWLEDGE_MAX_BULK_FILES=20
KNOWLEDGE_MAX_DOCUMENT_MIB=50
KNOWLEDGE_MAX_BULK_MIB=100
KNOWLEDGE_PARSER_TIMEOUT_SECONDS=600
KNOWLEDGE_WORKER_CONCURRENCY=3
KNOWLEDGE_RETRIEVAL_CACHE_TTL_SECONDS=60
