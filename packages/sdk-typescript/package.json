{
  "name": "@montenegrina/sdk-typescript",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../contracts/openapi/openapi.yaml -o src/schema.ts && prettier --write src/schema.ts",
    "build": "pnpm generate && tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "pnpm generate && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "openapi-fetch": "^0.15.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.0"
  }
}
