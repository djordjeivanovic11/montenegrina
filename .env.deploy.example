AWS_PROFILE=default
AWS_REGION=eu-central-1
PROJECT_NAME=montenegrina
ENVIRONMENT=production

# Public URLs (CloudFront domain after first deploy, or custom domain)
PUBLIC_WEB_URL=
PUBLIC_API_URL=
PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
CORS_ORIGINS=

# LiveKit Cloud (wss://...)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_SIP_INBOUND_TRUNK_ID=
LIVEKIT_WEBHOOK_SECRET=
VOICE_AGENT_SERVICE_SECRET=
LIVEKIT_EGRESS_S3_ACCESS_KEY_ID=
LIVEKIT_EGRESS_S3_SECRET_ACCESS_KEY=
PHONE_INTEGRATIONS_ENABLED=false

# Production model providers
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_MONTENEGRIN_VOICE_ID=

# Transactional email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Montenegrina <noreply@montenegrina.me>

# Billing (optional)
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Observability (optional)
SENTRY_DSN=
SENTRY_ENABLED=false

# Created once by the idempotent database bootstrap task.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Safety/cost controls. Set false for disposable staging only.
TF_VAR_deletion_protection=true
TF_VAR_single_nat_gateway=true
